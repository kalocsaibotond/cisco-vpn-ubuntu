#cloud-config

autoinstall:
  version: 1

  source:
    search_drivers: true
    id: ubuntu-server-minimal

  storage:
    config:
      - type: disk
        id: ubuntu-disk
        path: /dev/vdc
        wipe: superblock-recursive

      - type: format
        id: root-format
        volume: ubuntu-disk
        fstype: ext4

      - type: mount
        device: root-format
        path: /

  drivers:
    install: true

  shutdown: poweroff

  identity:
    realname: 'VPN user'
    username: vpnuser
    password: "$1$V0/SeOln$5KjvZfqIzL.w1HMehRUN6."  # The password is vpnuser .
    hostname: ubuntu-pc

  keyboard:
    layout: hu

  timezone: "Europe/Budapest"

  network:
    version: 2
    ethernets:
      modern-interfaces:
        match:
          name: "en*"
        dhcp4: true
      legacy-interfaces:
        match:
          name: "eth*"
        dhcp4: true

  apt:
    mirror-selection:
      primary:
        - uri: "http://hu.archive.ubuntu.com/ubuntu"
    sources:
      xtradeb.list:
        sources: "deb https://ppa.launchpadcontent.net/xtradeb/apps/ubuntu jammy main"
        keyid: 5301 FA4F D932 44FB C6F6 1499 82BB 6851 C64F 6880

  updates: all

  codecs:
    install: true

  late-commands:
    - curtin in-target -- systemctl set-default multi-user.target
    - curtin in-target -- systemctl disable NetworkManager.service
    - curtin in-target -- systemctl disable NetworkManager-wait-online.service
    - |  # Apply Caps Lock - Esc key swap.
      root_path=/target
      mkdir -p "$root_path/etc/default"
      if ! grep -q "XKBOPTIONS=" "$root_path/etc/default/keyboard"; then
        echo 'set number
      $ append

      XKBOPTIONS="caps:swapescape"
      .
      xit' | ex "$root_path/etc/default/keyboard"

      elif ! grep -q "caps:swapescape" "$root_path/etc/default/keyboard"; then
        echo 'set number
      /XKBOPTIONS=/
      . s/"\\(.*\\)"/"\\1,caps:swapescape"/g
      xit' | ex "$root_path/etc/default/keyboard"

      fi

  user-data:
    growpart:
      mode: auto
      devices: ['/']
    resize_rootfs: True

    write_files:
      - path: /etc/skel/.profile
        permissions: '0777'
        content: |
          # ~/.profile: executed by the command interpreter for login shells.
          # This file is not read by bash(1), if ~/.bash_profile or ~/.bash_login
          # exists.
          # see /usr/share/doc/bash/examples/startup-files for examples.
          # the files are located in the bash-doc package.

          # the default umask is set in /etc/profile; for setting the umask
          # for ssh logins, install and configure the libpam-umask package.
          #umask 022

          # if running bash
          if [ -n "$BASH_VERSION" ]; then
            # include .bashrc if it exists
            if [ -f "$HOME/.bashrc" ]; then
              . "$HOME/.bashrc"
            fi
          fi

          # set PATH so it includes user's private bin if it exists
          if [ -d "$HOME/bin" ] ; then
            PATH="$HOME/bin:$PATH"
          fi

          # set PATH so it includes user's private bin if it exists
          if [ -d "$HOME/.local/bin" ] ; then
            PATH="$HOME/.local/bin:$PATH"
          fi

          export DISPLAY=:0

      - path: /etc/skel/.xsession
        permissions: '0777'
        content: |
          exec dbus-run-session -- startlxde

      - path: /etc/skel/vpn-launch.sh
        permissions: '0777'
        content: |
          #!/bin/sh
          dbus-run-session -- /opt/cisco/anyconnect/bin/vpnui &

      - path: /etc/skel/enter-main-chroot.sh
        permissions: '0777'
        content: |
          #!/bin/sh
          mount_point="/mnt/main-root"
          lockfile="/run/lock/main_system_chroot_counter.lock"

          mount_directories()(
            mount_dirs='/dev /dev/pts /proc /sys /run /tmp'
            for mount_dir in $mount_dirs; do
              if [ -z "$(findmnt "$mount_point$mount_dir")" ]; then
                sudo mount --bind "$mount_dir" "$mount_point$mount_dir"
              fi
            done
            if [ -z "$(findmnt  "${mount_point}/mnt/cisco-vpn-ubuntu")" ]; then
              sudo mkdir -p  "${mount_point}/mnt/cisco-vpn-ubuntu"
              sudo mount --bind "/" "${mount_point}/mnt/cisco-vpn-ubuntu"
            fi
          )

          unmount_directories()(
            mount_dirs='/dev/pts /dev /proc /sys /run /tmp'
            for mount_dir in $mount_dirs; do
              sudo umount "$mount_point$mount_dir"
            done
            sudo umount "${mount_point}/mnt/cisco-vpn-ubuntu"
          )


          increase_counter(){
            if [ ! -f "$lockfile" ]; then
              counter=1
            else
              counter=$(cat $lockfile)
              counter=$((counter + 1))
            fi
            echo "$counter" > $lockfile
          }

          decrease_counter(){
            if [ ! -f "$lockfile" ]; then
              counter=0
            else
              counter=$(cat $lockfile)
              if [ 0 -lt "$counter" ]; then
                counter=$((counter - 1))
              else
                counter=0
              fi
            fi
            echo "$counter" > $lockfile
          }

          mount_directories

          increase_counter

          sudo chroot "$mount_point" bash

          decrease_counter

          if [ 0 -ge "$counter" ]; then
            unmount_directories
          fi

      - path: /etc/skel/enter-main-nspawn.sh
        permissions: '0777'
        content: |
          #!/bin/sh

          bind_args=""
          for path in /dev/tty*; do
            bind_args="$bind_args --bind=$path"
          done
          for path in /dev/dri/*; do
            bind_args="$bind_args --bind=$path"
          done
          for path in /dev/input/*; do
            bind_args="$bind_args --bind=$path"
          done
          bind_args="$bind_args --bind=/run/udev/data"

          sudo systemd-nspawn -D /mnt/main-root $bind_args \
            -M main-system \

    runcmd:
      - [mkdir, -p, /home/vpnuser]
      - cp -r /etc/skel/** /home/vpnuser/
      - /opt/*vpn*.sh

    packages:
      - wpasupplicant
      - rfkill
      - iputils-ping
    # Desktop
      - alsa-utils
      - xorg
      - xinit
      - stterm
      - neovim
      - less
    # Stuff needed for the Cisco VPN client.
      - lxde-core # For vpn client installation.
      - libwebkit2gtk-4.0-37 # For web SSO authentication.
      - clamav
      - ufw

  packages:
    - wpasupplicant
    - rfkill
    - iputils-ping
  # Desktop
    - alsa-utils
    - xorg
    - xinit
    - stterm
    - neovim
    - less
  # Stuff needed for the Cisco VPN client.
    - lxde-core # For vpn client installation.
    - libwebkit2gtk-4.0-37 # For web SSO authentication.
    - clamav
    - ufw

